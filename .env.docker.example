# Variáveis usadas pelo docker-compose para configurar o container em runtime.
# Copie este arquivo para .env.docker e preencha com os valores reais.
#
#   cp .env.docker.example .env.docker
#
# A publishable key do Supabase é pública (protegida por RLS), mas a URL e a
# chave devem apontar para o ambiente correto (dev, homolog ou prod).

# Porta exposta no host (a aplicação sempre roda na porta 80 dentro do container).
APP_PORT=8080

VITE_APP_NAME="Busca Ativa Replay Sports"
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_sua_chave_publica"
